PORT=3001
MONGODB_URI=mongodb://127.0.0.1:27017/gerenciador-financeiro
JWT_SECRET=troque-esta-chave-por-uma-chave-forte-minimo-32-chars
NODE_ENV=development
COOKIE_SECURE=false
AUTH_COOKIE_NAME=financeiro_auth
REFRESH_COOKIE_NAME=financeiro_refresh
CSRF_COOKIE_NAME=financeiro_csrf

# Em produção, defina FRONTEND_URL com a URL exata do seu frontend.
# Em desenvolvimento, localhost já é permitido automaticamente.
FRONTEND_URL=http://localhost:5173

# Origens CORS adicionais separadas por vírgula (ex.: deploy em Vercel)
# CORS_ORIGINS=https://seu-frontend.vercel.app

# TTL do cache de indicadores financeiros em ms (padrão: 600000 = 10 min)
# INDICATORS_CACHE_TTL_MS=600000
